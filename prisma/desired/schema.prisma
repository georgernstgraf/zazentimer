datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// The underlying table does not contain a valid unique identifier and can therefore currently not be handled by Prisma Client.
model android_metadata {
  locale String?

  @@ignore
}

model bells {
  id                   Int                    @id @default(autoincrement()) @map("_id")
  name                 String                 @default("")
  uri                  String                 @default("")
  is_builtin           Int                    @default(0)
  sections             sections[]
  session_bell_volumes session_bell_volumes[]
}

model room_master_table {
  id            Int     @id @default(autoincrement())
  identity_hash String?
}

model sections {
  id         Int      @id @default(autoincrement()) @map("_id")
  name       String
  duration   Int
  rank       Int
  bellcount  Int
  bellpause  Int
  bellId     Int
  bells      bells    @relation(fields: [bellId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  fk_session Int
  sessions   sessions @relation(fields: [fk_session], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([bellId], map: "index_sections_bellId")
  @@index([fk_session], map: "index_sections_fk_session")
}

model session_bell_volumes {
  id         Int      @id @default(autoincrement()) @map("_id")
  volume     Int
  bellId     Int
  bells      bells    @relation(fields: [bellId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  fk_session Int
  sessions   sessions @relation(fields: [fk_session], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@unique([fk_session, bellId], map: "index_session_bell_volumes_fk_session_bell_belluri")
  @@index([bellId], map: "index_session_bell_volumes_bellId")
  @@index([fk_session], map: "index_session_bell_volumes_fk_session")
}

model sessions {
  id                   Int                    @id @default(autoincrement()) @map("_id")
  name                 String
  description          String
  rank                 Int
  sections             sections[]
  session_bell_volumes session_bell_volumes[]
}
