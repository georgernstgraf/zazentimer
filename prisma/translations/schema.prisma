generator client {
  provider = "prisma-client"
  output   = "../generatedprismaclient"
  runtime  = "deno"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// A locale that translations target (e.g., "de" for values-de).
model languages {
  id                     Int                      @id @default(autoincrement())
  posix_code             String                   @unique /// _region is nice to have, but optional here
  bcp_47                 String                   @unique
  iso_639_3              String
  whisper_response       String?
  directory              String                   @unique
  english_name           String /// The English name of the language
  votes                  votes[]
  language_proficiencies language_proficiencies[]
}

/// A source English string that needs translation.
/// Note: Only translatable strings (<string> without translatable="false")
/// from app/src/main/res/values/strings.xml are seeded here.
/// Non-translatable strings (e.g. app_name, platform internals) are excluded.
model master_strings {
  id    Int     @id @default(autoincrement())
  text  String  @unique
  votes votes[]
}

/// LLM Model (gemini-3.1-pro, opus-4.7, etc..)
model llm_models {
  id                     Int                      @id @default(autoincrement())
  name                   String                   @unique
  votes                  votes[]
  language_proficiencies language_proficiencies[]
}

/// self-assessment of llms
model language_proficiencies {
  id         Int          @id @default(autoincrement())
  level      Int
  llm_models llm_models[]
  languages  languages[]
}

/// Individual Votings of large models
model votes {
  id            Int            @id @default(autoincrement())
  language      languages      @relation(fields: [languagesId], references: [id], onDelete: Cascade)
  llm_model     llm_models     @relation(fields: [llm_modelsId], references: [id], onDelete: Cascade)
  master_string master_strings @relation(fields: [master_stringsId], references: [id], onDelete: Cascade)

  translation String
  created_at  DateTime @default(now())

  languagesId      Int
  llm_modelsId     Int
  master_stringsId Int

  @@unique([languagesId, llm_modelsId, master_stringsId, translation])
}
