{
  "tasks": {
    "prisma:translationsgenerateclient": "deno -A prisma generate --schema=translations/schema.prisma",
    "prisma:translationsseed": "deno run --env-file=translations/.env -A translations/seed.ts",
    "prisma:translationszap": "deno run  -A prisma db push --schema=translations/schema.prisma"
  },
  "imports": {
    "@std/assert": "jsr:@std/assert@1",
    "prisma": "npm:prisma@^6.19.3",
    "@prisma/client": "npm:@prisma/client@^6.19.3",
    "prismaclient": "./generatedprismaclient/client.ts"
  },
  "fmt": {
    "indentWidth": 4
  }
}
