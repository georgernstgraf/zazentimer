<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="timerViewStyleDark" parent="">
        <item name="colorMarkerLine">@color/colorDarkMarkerLine</item>
        <item name="colorMarkerTriangle">@color/colorDarkMarkerTriangle</item>
        <item name="currentSectionColor">@color/colorDarkCurrentSection</item>
        <item name="nextSectionColor">@color/colorDarkNextSection</item>
        <item name="previousSectionsColor">@color/colorDarkPreviousSection</item>
        <item name="remainingSectionsColor">@color/colorDarkRemainingSections</item>
    </style>
    <style name="timerViewStyleLight" parent="">
        <item name="colorMarkerLine">@color/colorMarkerLine</item>
        <item name="colorMarkerTriangle">@color/colorMarkerTriangle</item>
        <item name="currentSectionColor">@color/colorCurrentSection</item>
        <item name="nextSectionColor">@color/colorNextSection</item>
        <item name="previousSectionsColor">@color/colorPreviousSection</item>
        <item name="remainingSectionsColor">@color/colorRemainingSections</item>
    </style>

    <style name="zenIcon" parent="">
        <item name="android:src">?attr/zenIconSrc</item>
    </style>
    <style name="bellcount" parent="@style/Widget.AppCompat.Button">
        <item name="android:gravity">center</item>
        <item name="android:background">@drawable/bellcount</item>
        <item name="android:layout_width">40dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:layout_margin">5dp</item>
    </style>
    <style name="bellgapseconds" parent="@style/Widget.AppCompat.Button">
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">?attr/colorPrimary</item>
        <item name="android:gravity">center</item>
        <item name="android:background">@drawable/bellgap</item>
        <item name="android:layout_width">40dp</item>
        <item name="android:layout_height">40dp</item>
        <item name="android:layout_margin">5dp</item>
    </style>
    <style name="captionTextView" parent="">
        <item name="android:layout_marginTop">@dimen/caption_margin</item>
        <item name="android:textAllCaps">true</item>
    </style>
    <style name="messagetext" parent="">
        <item name="android:textSize">18sp</item>
        <item name="android:textColor">#8affffff</item>
        <item name="android:lineSpacingMultiplier">1.2</item>
    </style>
    <style name="messagetitle" parent="">
        <item name="android:textSize">24sp</item>
        <item name="android:textColor">#deffffff</item>
    </style>
    <style name="messageview" parent="">
        <item name="android:background">#f0404040</item>
    </style>
</resources>
