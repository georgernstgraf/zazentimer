    <string name="about1">Zazen Meditation Timer — En enkel meditasjonstimer med tilpassbare seksjoner, klokkelyder og øktadministrasjon.</string>
    <string name="about2">Opprinnelig laget av Stefan Gaffga. Vedlikeholdes nå av Georg Graf.&lt;br&gt;&lt;br&gt;Takk til Winfried fra &lt;a href="http://www.meditationsuhren.de">http://www.meditationsuhren.de&lt;/a&gt; for å tilby fantastiske klokkelyder!</string>
    <string name="about3">&lt;a href="https://github.com/georgernstgraf/zazentimer/issues">Rapporter problemer på GitHub&lt;/a&gt;</string>
    <string name="app_description">Denne applikasjonen lar brukeren definere meditasjonsøkter og gir en timer med visuell og hørbar tilbakemelding når en del av eller hele meditasjonen er over.</string>
