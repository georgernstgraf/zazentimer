    <string name="abbrechen">Anula</string>
    <string name="about1">Temporizator de meditație Zazen — Un temporizator de meditație simplu cu secțiuni personalizabile, sunete de clopoței și gestionarea sesiunilor.</string>
    <string name="about2">Creat inițial de Stefan Gaffga. Întreținut în prezent de Georg Graf.&lt;br&gt;&lt;br&gt;Mulțumim lui Winfried de la &lt;a href="http://www.meditationsuhren.de"&gt;http://www.meditationsuhren.de&lt;/a&gt; pentru că a furnizat sunete de clopoțe atât de grozave!</string>
    <string name="about3">&lt;a href="https://github.com/georgernstgraf/zazentimer/issues"&gt;Raportați probleme pe GitHub&lt;/a&gt;</string>
    <string name="app_description">Această aplicație permite utilizatorului să definească un set de sesiuni de meditație și oferă un cronometru cu feedback vizual și sonor atunci când o parte sau întreaga meditație se termină.</string>
