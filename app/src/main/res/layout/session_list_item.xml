<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="12dp"
    android:gravity="center_vertical"
    android:background="?android:attr/selectableItemBackground">
    <ImageView
        android:id="@+id/drag_handle"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_drag_handle"
        android:contentDescription="@string/content_desc_drag_handle"
        android:padding="4dp" />
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1">
        <TextView
            android:id="@+id/spinner_text_1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textStyle="bold"
            android:textSize="16sp" />
        <TextView
            android:id="@+id/bell_name_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp" />
        <TextView
            android:id="@+id/spinner_text_2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="14sp" />
    </LinearLayout>
    <ImageButton
        android:id="@+id/section_overflow"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:layout_gravity="center_vertical"
        android:src="@drawable/ic_more_vert"
        android:contentDescription="@string/content_desc_section_actions"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:padding="6dp" />
</LinearLayout>
