<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:navigationIcon="?attr/homeAsUpIndicator"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:id="@+id/system_volume_section_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/system_volume_section_title"
                android:textAppearance="?attr/textAppearanceSubtitle1"/>

            <TextView
                android:id="@+id/system_volume_subtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/system_volume_subtitle"
                android:textSize="12sp"
                android:textColor="?android:attr/textColorSecondary"
                android:paddingBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingBottom="8dp">

                <SeekBar
                    android:id="@+id/system_volume_seekbar"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"/>

                <TextView
                    android:id="@+id/system_volume_label"
                    android:layout_width="48dp"
                    android:layout_height="wrap_content"
                    android:gravity="end"
                    android:textSize="12sp"
                    android:layout_marginStart="8dp"/>

            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="?android:attr/listDivider"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="12dp"/>

            <TextView
                android:id="@+id/bell_dimming_section_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/bell_dimming_section_title"
                android:textAppearance="?attr/textAppearanceSubtitle1"/>

            <TextView
                android:id="@+id/dimming_explanation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/bell_volume_dim_explanation"
                android:textSize="14sp"
                android:textColor="?android:attr/textColorSecondary"
                android:paddingBottom="12dp"/>

            <TextView
                android:id="@+id/no_bells_text"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/no_bells_configured"
                android:visibility="gone"
                android:gravity="center"
                android:padding="16dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/bell_volume_list"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

        </LinearLayout>

    </ScrollView>

</LinearLayout>
